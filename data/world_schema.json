{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Racetrack",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string"
    },
    "creator": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "grid_size": {
      "type": "object",
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200
        },
        "height": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200
        }
      },
      "required": ["width", "height"],
      "additionalProperties": false
    },
    "laps": {
      "type": "integer",
      "minimum": 1,
      "default": 3
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard", "extreme"]
    },
    "tile_size": {
      "type": "integer",
      "minimum": 8,
      "maximum": 128,
      "default": 32
    },
    "tile_palette": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "minProperties": 1
    },
    "grid": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string"
          }
        },
        "required": ["id", "x", "y"],
        "additionalProperties": false
      },
      "minItems": 3
    },
    "starting_grid": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "direction": {
            "type": "string",
            "enum": ["north", "south", "east", "west"]
          }
        },
        "required": ["x", "y", "direction"],
        "additionalProperties": false
      },
      "minItems": 4
    },
    "decorations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        },
        "required": ["type", "x", "y"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "name",
    "grid_size",
    "tile_palette",
    "grid",
    "checkpoints",
    "starting_grid"
  ],
  "additionalProperties": false
}
